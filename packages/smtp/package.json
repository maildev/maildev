{
  "name": "@maildev/smtp",
  "version": "3.0.0-rc.1",
  "description": "SMTP server for MailDev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/set-version.mjs",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "maildev",
    "smtp",
    "email",
    "testing"
  ],
  "author": "Dan Farrelly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://github.com/maildev/maildev.git",
    "directory": "packages/smtp"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@maildev/core": "workspace:*",
    "smtp-server": "^3.19.2",
    "nodemailer": "^9.0.3",
    "mailparser": "^3.9.14",
    "dompurify": "^3.4.11",
    "jsdom": "^26.0.0",
    "wildstring": "^1.0.8"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/mailparser": "^3.4.5",
    "@types/nodemailer": "6.4.17",
    "@types/smtp-server": "^3.5.10",
    "vitest": "^3.2.7",
    "typescript": "^5.7.3"
  }
}
