{
  "name": "maildev",
  "version": "3.0.0-alpha.0",
  "description": "SMTP Server and Web Interface for reading and testing emails during development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "maildev": "./dist/bin/maildev.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "cli": "chmod +x ./dist/bin/maildev.js && ./dist/bin/maildev.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "email",
    "e-mail",
    "mail",
    "maildev",
    "mailcatcher",
    "testing",
    "development",
    "smtp"
  ],
  "author": "Dan Farrelly",
  "license": "MIT",
  "homepage": "http://maildev.github.io/maildev/",
  "repository": {
    "type": "git",
    "url": "http://github.com/maildev/maildev.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@maildev/core": "workspace:*",
    "@maildev/smtp": "workspace:*",
    "@maildev/api": "workspace:*",
    "@maildev/mcp": "workspace:*",
    "@maildev/ui": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
