{
  "name": "@maildev/api",
  "version": "3.0.0-rc.1",
  "description": "REST API and WebSocket server for MailDev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node scripts/set-version.mjs",
    "dev": "tsx watch src/dev.ts",
    "dev:build": "tsc --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "maildev",
    "api",
    "rest",
    "websocket"
  ],
  "author": "Dan Farrelly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://github.com/maildev/maildev.git",
    "directory": "packages/api"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@maildev/core": "workspace:*",
    "@maildev/mcp": "workspace:*",
    "@maildev/smtp": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
